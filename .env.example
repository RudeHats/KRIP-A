# ─────────────────────────────────────────────────────────────────────────────
# AQI Dashboard — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env (for Chatbot.py) and .env.local (for Next.js)
# and fill in your real API keys. Never commit the actual .env files.
# ─────────────────────────────────────────────────────────────────────────────

# ── Next.js (Frontend) ────────────────────────────────────────────────────────
# WAQI API token — get yours free at https://aqicn.org/api/
NEXT_PUBLIC_WAQI_TOKEN=your_waqi_token_here

# ── Python Backend (Chatbot.py / FastAPI) ────────────────────────────────────
# Groq API key — get yours at https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# WAQI API token (same token as above, used by Python backend)
WAQI_API_TOKEN=your_waqi_token_here

# HuggingFace API token — for the optional LSTM AQI prediction model
# Get yours at https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# HuggingFace model inference URL (optional — defaults to placeholder)
# HF_API_URL=https://api-inference.huggingface.co/models/your-username/your-lstm-model
